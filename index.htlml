<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>Dashboard Colas Genesys</title>

<style>
  body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f6f8;
  }

  .container {
    padding: 20px;
  }

  h1 {
    font-size: 20px;
    margin-bottom: 15px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th {
    background: #c7b299;
    color: #000;
    padding: 10px;
    text-align: left;
  }

  td {
    background: #9aa3ad;
    padding: 10px;
    border-bottom: 2px dotted #5f6b78;
    color: #000;
  }

  td.name {
    font-weight: bold;
  }

  .metric {
    text-align: center;
    background: #dfe3e8;
    border-left: 1px solid #ccc;
  }

</style>
</head>

<body>

<div class="container">
  <h1>Monitoreo de Colas</h1>

  <table>
    <tr>
      <th>Cola</th>
      <th>Nombre Técnico</th>
      <th>En Espera</th>
      <th>Agentes Activos</th>
      <th>TMO (seg)</th>
    </tr>

    <tr>
      <td class="name">BANCA SEGUROS</td>
      <td>Q_INBOUND_GE_SEGUROS</td>
      <td class="metric">12</td>
      <td class="metric">8</td>
      <td class="metric">320</td>
    </tr>

    <tr>
      <td class="name">BANCA SEGUROS RETENCIONES</td>
      <td>Q_INBOUND_GE_SEGUROSRETENCIONES</td>
      <td class="metric">5</td>
      <td class="metric">6</td>
      <td class="metric">280</td>
    </tr>

    <tr>
      <td class="name">ONR</td>
      <td>Q_INBOUND_GE_ONR911</td>
      <td class="metric">2</td>
      <td class="metric">4</td>
      <td class="metric">150</td>
    </tr>

    <tr>
      <td class="name">AUTORIZACIONES</td>
      <td>Q_INBOUND_GE_AUTORIZACIONES</td>
      <td class="metric">9</td>
      <td class="metric">7</td>
      <td class="metric">210</td>
    </tr>

    <tr>
      <td class="name">OPERACIONES TRUNCAS ATM</td>
      <td>Q_INBOUND_GE_OT305</td>
      <td class="metric">3</td>
      <td class="metric">5</td>
      <td class="metric">180</td>
    </tr>

  </table>
</div>

</body>
</html>
